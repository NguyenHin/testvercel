<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - BookTotal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }

        /* Sidebar Styles */
        .sidebar {
            height: 100vh;
            background-color: #1a1a2e;
            color: white;
            position: fixed;
            width: 250px;
            padding: 20px 0;
            display: flex;
            flex-direction: column;
        }

        .sidebar-header { padding: 0 20px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 20px; }

        .sidebar a {
            color: #adb5bd;
            text-decoration: none;
            padding: 12px 25px;
            display: block;
            transition: 0.3s;
            font-weight: 500;
            display: flex;
            align-items: center;
        }

        .sidebar a:hover, .sidebar a.active {
            background-color: #c49b63;
            color: white;
            border-left: 4px solid #fff;
        }

        .sidebar i { width: 25px; text-align: center; margin-right: 10px; }

        .sidebar-footer { margin-top: auto; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 10px; }

        /* Main Content Styles */
        .main-content { margin-left: 250px; padding: 30px; }

        .stat-card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            transition: 0.3s;
            background: white;
            overflow: hidden;
            height: 100%;
        }

        .stat-card:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.1); }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin-bottom: 15px;
        }

        .card-title { font-weight: 700; color: #333; font-size: 1.1rem; }
        .card-desc { color: #777; font-size: 0.85rem; margin-bottom: 20px; }

        .btn-go {
            background-color: #f8f9fa;
            color: #333;
            border: none;
            width: 100%;
            padding: 8px;
            border-radius: 8px;
            font-weight: 600;
            transition: 0.2s;
            font-size: 0.9rem;
        }
        .stat-card:hover .btn-go { background-color: #1a1a2e; color: white; }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <h3 class="text-center fw-bold text-white mb-0">BOOKTOTAL</h3>
            <p class="text-center text-white-50 small mb-0">Admin Panel</p>
        </div>

        <a href="/admin" class="active"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
        <a href="/"><i class="fas fa-globe"></i> Xem Website</a>

        <div class="sidebar-footer">
            <a href="/auth/logout" class="text-danger"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="fw-bold text-dark mb-1">Tổng quan hệ thống</h2>
                <p class="text-muted">Chào mừng trở lại, Admin!</p>
            </div>
            <div class="date text-muted"><i class="far fa-calendar-alt me-2"></i> <%= new Date().toLocaleDateString('vi-VN') %></div>
        </div>

        <div class="row g-4">
            <!-- Card Đơn hàng -->
            <div class="col-md-4 col-lg-3">
                <div class="card stat-card p-4">
                    <div class="stat-icon bg-info bg-opacity-10 text-info">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <h5 class="card-title">Đơn hàng</h5>
                    <p class="card-desc">Xử lý đơn hàng mới và vận chuyển.</p>
                    <a href="/admin/orders" class="btn btn-go">Truy cập <i class="fas fa-arrow-right ms-2"></i></a>
                </div>
            </div>

            <!-- Card Kho -->
            <div class="col-md-4 col-lg-3">
                <div class="card stat-card p-4">
                    <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                        <i class="fas fa-warehouse"></i>
                    </div>
                    <h5 class="card-title">Kho hàng</h5>
                    <p class="card-desc">Kiểm soát tồn kho và nhập hàng.</p>
                    <a href="/admin/inventory" class="btn btn-go">Truy cập <i class="fas fa-arrow-right ms-2"></i></a>
                </div>
            </div>

            <!-- Card Sản phẩm -->
            <div class="col-md-4 col-lg-3">
                <div class="card stat-card p-4">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                        <i class="fas fa-book"></i>
                    </div>
                    <h5 class="card-title">Sản phẩm</h5>
                    <p class="card-desc">Thêm, sửa, xóa sách.</p>
                    <a href="/admin/products" class="btn btn-go">Truy cập <i class="fas fa-arrow-right ms-2"></i></a>
                </div>
            </div>

            <!-- Card Thống kê -->
            <div class="col-md-4 col-lg-3">
                <div class="card stat-card p-4">
                    <div class="stat-icon bg-secondary bg-opacity-10 text-secondary">
                        <i class="fas fa-chart-pie"></i>
                    </div>
                    <h5 class="card-title">Thống kê</h5>
                    <p class="card-desc">Báo cáo doanh thu và hiệu quả.</p>
                    <a href="/admin/stats" class="btn btn-go">Truy cập <i class="fas fa-arrow-right ms-2"></i></a>
                </div>
            </div>

            <!-- Card Người dùng -->
            <div class="col-md-4 col-lg-3">
                <div class="card stat-card p-4">
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="fas fa-users"></i>
                    </div>
                    <h5 class="card-title">Người dùng</h5>
                    <p class="card-desc">Quản lý tài khoản khách hàng.</p>
                    <a href="/admin/user" class="btn btn-go">Truy cập <i class="fas fa-arrow-right ms-2"></i></a>
                </div>
            </div>

            <!-- Card Đánh giá -->
            <div class="col-md-4 col-lg-3">
                <div class="card stat-card p-4">
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                        <i class="fas fa-star"></i>
                    </div>
                    <h5 class="card-title">Đánh giá</h5>
                    <p class="card-desc">Kiểm duyệt bình luận.</p>
                    <a href="/admin/reviews" class="btn btn-go">Truy cập <i class="fas fa-arrow-right ms-2"></i></a>
                </div>
            </div>
        </div>
    </div>

</body>
</html>