<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trang Quản Trị - Danh sách Người Dùng</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body { background-color: #f8f9fa; }
        .admin-header {
            background-color: #1a1a2e;
            color: white;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 3px solid #c49b63;
        }
        .sidebar {
            min-height: 100vh;
            background-color: #fff;
            padding-top: 20px;
            border-right: 1px solid #ddd;
        }
        .sidebar a {
            display: block;
            padding: 12px 15px;
            color: #333;
            text-decoration: none;
            margin-bottom: 5px;
            font-weight: 500;
            transition: 0.2s;
        }
        .sidebar a:hover { background-color: #f0f0f0; color: #0d6efd; }
        .sidebar a.active {
            background-color: #e9ecef;
            color: #0d6efd;
            border-left: 4px solid #0d6efd;
        }
        .main-content { padding: 20px; }
        .page-title {
            font-size: 24px;
            font-weight: bold;
            color: #333;
            margin-bottom: 20px;
            border-bottom: 2px solid #c49b63;
            display: inline-block;
            padding-bottom: 5px;
        }
    </style>
</head>
<body>

    <div class="admin-header">
        <h2><a href="/admin" class="text-white text-decoration-none">Khu vực quản trị</a></h2>
        <a href="/auth/logout" class="btn btn-sm btn-danger">Đăng xuất</a>
    </div>

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 sidebar">
                <a href="/admin"><i class="fas fa-tachometer-alt me-2"></i> Dashboard</a>
                <a href="/admin/products"><i class="fas fa-box me-2"></i> Quản lý Sản phẩm</a>
                <a href="/admin/users" class="active"><i class="fas fa-users me-2"></i> Quản lý Người dùng</a>
                <hr>
                <a href="/"><i class="fas fa-home me-2"></i> Về trang chủ</a>
            </div>

            <div class="col-md-10 main-content">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="page-title"><i class="fas fa-list"></i> Danh sách Người dùng</h3>
                    <a href="/admin/users/add" class="btn btn-success"><i class="fas fa-user-plus"></i> Thêm người dùng</a>
                </div>

                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>Username</th>
                                    <th>Họ tên</th>
                                    <th>Email</th>
                                    <th>Vai trò</th>
                                    <th class="text-end">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (users && users.length > 0) { %>
                                    <% users.forEach(user => { %>
                                        <tr>
                                            <td><%= user.id %></td>
                                            <td class="fw-bold"><%= user.username %></td>
                                            <td><%= user.full_name %></td>
                                            <td><%= user.email %></td>
                                            <td>
                                                <% if (user.role && user.role.toLowerCase() === 'admin') { %>
                                                    <span class="badge bg-danger">ADMIN</span>
                                                <% } else { %>
                                                    <span class="badge bg-primary">USER</span>
                                                <% } %>
                                            </td>
                                            <td class="text-end">
                                                <a href="/admin/users/edit/<%= user.id %>" class="btn btn-primary btn-sm me-1">
                                                    <i class="fas fa-edit"></i> Sửa
                                                </a>
                                                <a href="/admin/users/delete/<%= user.id %>"
                                                   class="btn btn-danger btn-sm"
                                                   onclick="return confirm('CẢNH BÁO: Bạn có chắc muốn xóa user này?');">
                                                    <i class="fas fa-trash"></i> Xóa
                                                </a>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-4">Chưa có user nào.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>