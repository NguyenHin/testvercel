<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Thanh toán - Bookstore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
        .checkout-container { background: white; border-radius: 12px; padding: 30px; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05); margin-top: 30px; margin-bottom: 50px; }
        .section-title { font-size: 1.2rem; font-weight: 700; color: #333; margin-bottom: 20px; border-bottom: 2px solid #f0f0f0; padding-bottom: 10px; text-transform: uppercase; }
        .form-label { font-weight: 600; color: #555; font-size: 0.9rem; }
        .form-control, .form-select { padding: 10px 15px; border-radius: 8px; border: 1px solid #ddd; }
        .order-summary { background: #fafafa; border-radius: 8px; padding: 20px; border: 1px solid #eee; }
        .summary-row { display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 0.95rem; }
        .summary-total { font-weight: 700; font-size: 1.2rem; color: #C92127; border-top: 1px solid #ddd; padding-top: 15px; margin-top: 10px; }
        .btn-confirm { background-color: #C92127; color: white; font-weight: 700; width: 100%; padding: 12px; border: none; border-radius: 8px; transition: 0.3s; text-transform: uppercase; margin-top: 20px; }
        .btn-confirm:hover { background-color: #a11b20; }
        .payment-method-item { border: 1px solid #ddd; border-radius: 8px; padding: 15px; margin-bottom: 10px; cursor: pointer; display: flex; align-items: center; }
        .payment-method-item:hover { border-color: #C92127; background-color: #fff5f5; }
        .payment-icon { width: 35px; margin-right: 10px; object-fit: contain; }
    </style>
</head>

<body>
    <%- include('partials/menu') %>

    <div class="container">
        <form action="/order" method="POST" id="checkoutForm">
            <div class="row">
                <div class="col-lg-8">
                    <div class="checkout-container">
                        <h4 class="section-title"><i class="fas fa-map-marker-alt me-2 text-danger"></i> Địa chỉ giao hàng</h4>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Họ và tên người nhận</label>
                                <input type="text" class="form-control" name="full_name" value="<%= locals.user ? user.full_name : '' %>" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Số điện thoại</label>
                                <input type="tel" class="form-control" name="phone" value="<%= locals.user ? user.phone : '' %>" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" name="email" value="<%= locals.user ? user.email : '' %>" required>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Tỉnh/Thành phố</label>
                                <select class="form-select" id="province" required onchange="handleProvinceChange()">
                                    <option value="">Chọn Tỉnh/Thành</option>
                                </select>
                                <input type="hidden" name="province_name" id="province_name">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Quận/Huyện</label>
                                <select class="form-select" id="district" required onchange="loadWards()" disabled>
                                    <option value="">Chọn Quận/Huyện</option>
                                </select>
                                <input type="hidden" name="district_name" id="district_name">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Phường/Xã</label>
                                <select class="form-select" id="ward" required onchange="updateAddressString()" disabled>
                                    <option value="">Chọn Phường/Xã</option>
                                </select>
                                <input type="hidden" name="ward_name" id="ward_name">
                            </div>

                            <div class="col-12">
                                <label class="form-label">Địa chỉ cụ thể</label>
                                <input type="text" class="form-control" id="address_detail" required oninput="updateAddressString()">
                            </div>

                            <div class="col-12">
                                <label class="form-label">Ghi chú đơn hàng (Tùy chọn)</label>
                                <textarea class="form-control" name="note" rows="2" placeholder="Ví dụ: Giao giờ hành chính, gọi trước khi giao..."></textarea>
                            </div>

                            <input type="hidden" name="address" id="fullAddress">
                            <input type="hidden" name="shipping_fee" id="shippingFeeInput" value="0">
                        </div>
                    </div>

                    <div class="checkout-container">
                        <h4 class="section-title"><i class="fas fa-credit-card me-2 text-danger"></i> Phương thức thanh toán</h4>
                        <label class="payment-method-item">
                            <input type="radio" name="payment_method" value="COD" checked>
                            <img src="https://cdn-icons-png.flaticon.com/512/2331/2331941.png" class="payment-icon">
                            <span>Thanh toán khi nhận hàng (COD)</span>
                        </label>
                        <label class="payment-method-item">
                            <input type="radio" name="payment_method" value="VNPAY">
                            <img src="https://vinadesign.vn/uploads/images/2023/05/vnpay-logo-vinadesign-25-12-57-55.jpg" class="payment-icon">
                            <span>Ví VNPAY / QR Code</span>
                        </label>
                        <label class="payment-method-item">
                            <input type="radio" name="payment_method" value="MOMO">
                            <img src="https://developers.momo.vn/v3/assets/images/square-8c08a00f550e40a2efafea4a005b1232.png" class="payment-icon" style="border-radius: 4px;">
                            <span>Ví MoMo</span>
                        </label>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="checkout-container">
                        <h4 class="section-title">Đơn hàng của bạn</h4>
                        <div class="order-summary">
                            <% cart.forEach(item=> { %>
                                <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                                    <div style="font-size: 0.9rem;">
                                        <div class="fw-bold text-truncate" style="max-width: 180px;"><%= item.name %></div>
                                        <div class="text-muted small">x <%= item.quantity %></div>
                                    </div>
                                    <div class="fw-bold"><%= (item.price * item.quantity).toLocaleString('vi-VN') %> đ</div>
                                </div>
                            <% }); %>

                            <div class="summary-row mt-3">
                                <span>Tạm tính:</span>
                                <span><%= totalAmount.toLocaleString('vi-VN') %> đ</span>
                            </div>
                            <div class="summary-row" id="shippingRow" style="display: none;">
                                <span>Phí vận chuyển (<span id="regionLabel">...</span>):</span>
                                <span id="shippingFeeDisplay">0 đ</span>
                            </div>
                            <% if (productDiscount > 0) { %>
                                <div class="summary-row text-success">
                                    <span>Giảm giá:</span>
                                    <span>-<%= productDiscount.toLocaleString('vi-VN') %> đ</span>
                                </div>
                            <% } %>

                            <div class="summary-row summary-total">
                                <span>Tổng cộng:</span>
                                <span id="totalDisplay"><%= (totalAmount - productDiscount).toLocaleString('vi-VN') %> đ</span>
                            </div>
                        </div>
                        <button type="submit" class="btn-confirm">XÁC NHẬN ĐẶT HÀNG</button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <%- include('partials/footer') %>

    <script>
        const API_HOST = "https://provinces.open-api.vn/api/";
        const subtotal = <%= totalAmount %>;
        const discount = <%= productDiscount %>;

        const regions = {
            north: ["Hà Nội", "Hà Giang", "Cao Bằng", "Bắc Kạn", "Tuyên Quang", "Lào Cai", "Điện Biên", "Lai Châu", "Sơn La", "Yên Bái", "Hoà Bình", "Thái Nguyên", "Lạng Sơn", "Quảng Ninh", "Bắc Giang", "Phú Thọ", "Vĩnh Phúc", "Bắc Ninh", "Hải Dương", "Hải Phòng", "Hưng Yên", "Thái Bình", "Hà Nam", "Nam Định", "Ninh Bình"],
            central: ["Thanh Hóa", "Nghệ An", "Hà Tĩnh", "Quảng Bình", "Quảng Trị", "Thừa Thiên Huế", "Đà Nẵng", "Quảng Nam", "Quảng Ngãi", "Bình Định", "Phú Yên", "Khánh Hòa", "Ninh Thuận", "Bình Thuận", "Kon Tum", "Gia Lai", "Đắk Lắk", "Đắk Nông", "Lâm Đồng"],
            south: ["Hồ Chí Minh", "Bình Phước", "Tây Ninh", "Bình Dương", "Đồng Nai", "Bà Rịa", "Long An", "Tiền Giang", "Bến Tre", "Trà Vinh", "Vĩnh Long", "Đồng Tháp", "An Giang", "Kiên Giang", "Cần Thơ", "Hậu Giang", "Sóc Trăng", "Bạc Liêu", "Cà Mau"]
        };

        document.addEventListener("DOMContentLoaded", () => {
            fetch(API_HOST + "p/").then(r => r.json()).then(data => {
                let html = '<option value="">Chọn Tỉnh/Thành</option>';
                data.forEach(item => html += `<option value="${item.code}">${item.name}</option>`);
                document.getElementById('province').innerHTML = html;
            });
        });

        function handleProvinceChange() {
            const select = document.getElementById('province');
            const provinceName = select.options[select.selectedIndex].text;
            const shippingRow = document.getElementById('shippingRow');

            if (!select.value) {
                shippingRow.style.display = 'none';
                return;
            }

            document.getElementById('province_name').value = provinceName;
            let fee = 35000;
            let label = "Ngoại tỉnh";

            if (regions.north.some(r => provinceName.includes(r))) {
                fee = 45000; label = "Miền Bắc";
            } else if (regions.central.some(r => provinceName.includes(r))) {
                fee = 30000; label = "Miền Trung";
            } else if (regions.south.some(r => provinceName.includes(r))) {
                fee = 15000; label = "Miền Nam";
            }

            shippingRow.style.display = 'flex';
            document.getElementById('regionLabel').innerText = label;
            document.getElementById('shippingFeeInput').value = fee;
            document.getElementById('shippingFeeDisplay').innerText = fee.toLocaleString('vi-VN') + ' đ';
            document.getElementById('totalDisplay').innerText = (subtotal + fee - discount).toLocaleString('vi-VN') + ' đ';

            loadDistricts();
        }

        function loadDistricts() {
            const code = document.getElementById('province').value;
            const dSelect = document.getElementById('district');
            dSelect.innerHTML = '<option value="">Chọn Quận/Huyện</option>';
            document.getElementById('ward').innerHTML = '<option value="">Chọn Phường/Xã</option>';
            document.getElementById('ward').disabled = true;

            if (code) {
                fetch(API_HOST + `p/${code}?depth=2`).then(r => r.json()).then(data => {
                    data.districts.forEach(item => dSelect.innerHTML += `<option value="${item.code}">${item.name}</option>`);
                    dSelect.disabled = false;
                });
            } else { dSelect.disabled = true; }
            updateAddressString();
        }

        function loadWards() {
            const code = document.getElementById('district').value;
            const wSelect = document.getElementById('ward');
            document.getElementById('district_name').value = document.getElementById('district').options[document.getElementById('district').selectedIndex].text;
            wSelect.innerHTML = '<option value="">Chọn Phường/Xã</option>';

            if (code) {
                fetch(API_HOST + `d/${code}?depth=2`).then(r => r.json()).then(data => {
                    data.wards.forEach(item => wSelect.innerHTML += `<option value="${item.code}">${item.name}</option>`);
                    wSelect.disabled = false;
                });
            } else { wSelect.disabled = true; }
            updateAddressString();
        }

        function updateAddressString() {
            const p = document.getElementById('province_name').value;
            const d = document.getElementById('district_name').value;
            const wSelect = document.getElementById('ward');
            const w = wSelect.value ? wSelect.options[wSelect.selectedIndex].text : '';
            const detail = document.getElementById('address_detail').value;
            if (w) document.getElementById('ward_name').value = w;
            if (p && d && w && detail) document.getElementById('fullAddress').value = `${detail}, ${w}, ${d}, ${p}`;
        }
    </script>
</body>
</html>