<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quên mật khẩu - BookTotal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }
        .auth-card {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            width: 100%;
            max-width: 400px;
            border-top: 5px solid #1a1a2e;
        }
        .brand-logo {
            font-size: 2rem;
            font-weight: 800;
            color: #1a1a2e;
            text-align: center;
            margin-bottom: 10px;
            display: block;
            text-decoration: none;
            letter-spacing: 1px;
        }
        .auth-title {
            font-weight: 700;
            color: #333;
            text-align: center;
            margin-bottom: 25px;
            font-size: 1.1rem;
            text-transform: uppercase;
        }
        .form-label { font-weight: 600; color: #495057; font-size: 0.9rem; }
        .form-control {
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
            background-color: #f8f9fa;
        }
        .form-control:focus {
            background-color: #fff;
            border-color: #1a1a2e;
            box-shadow: 0 0 0 0.2rem rgba(26, 26, 46, 0.1);
        }
        .btn-auth {
            background: linear-gradient(45deg, #1a1a2e, #2c2c4e);
            color: white;
            font-weight: 700;
            padding: 12px;
            border-radius: 8px;
            width: 100%;
            border: none;
            transition: 0.3s;
            margin-top: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .btn-auth:hover {
            background: linear-gradient(45deg, #2c2c4e, #1a1a2e);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(26, 26, 46, 0.3);
        }
        .back-link {
            display: block;
            text-align: center;
            margin-top: 25px;
            color: #6c757d;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: 0.2s;
        }
        .back-link:hover { color: #1a1a2e; }

        /* Thông báo thành công nhẹ nhàng hơn */
        .success-msg {
            color: #099268;
            background-color: #f3fffa;
            padding: 10px;
            border-radius: 8px;
            font-size: 0.85rem;
            text-align: center;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <a href="/" class="brand-logo">BOOKTOTAL</a>
        <h2 class="auth-title">Quên mật khẩu</h2>

        <% if (locals.success) { %>
            <div class="success-msg">
                <i class="fas fa-check-circle me-2"></i><%= success %>
            </div>
        <% } %>

        <form action="/forgot-password" method="POST">
            <div class="mb-3">
                <label class="form-label">Địa chỉ Email</label>
                <input type="email" class="form-control" name="email" required>
            </div>
            <button type="submit" class="btn-auth">Gửi yêu cầu</button>
        </form>

        <a href="/" class="back-link">
            <i class="fas fa-arrow-left me-1"></i> Quay lại trang chủ
        </a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
