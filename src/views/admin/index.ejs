<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Dashboard - Quản trị hệ thống</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary: #4e73df;
            --success: #1cc88a;
            --info: #36b9cc;
            --warning: #f6c23e;
            --danger: #e74a3b;
            --dark: #1a1a2e;
        }

        body {
            background-color: #f8f9fc;
            font-family: 'Inter', 'Segoe UI', sans-serif;
        }

        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.1);
            transition: all 0.3s ease;
        }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 0.5rem 2rem 0 rgba(58, 59, 69, 0.15);
        }

        .stat-card {
            border-left: 4px solid;
        }

        .stat-card.primary { border-left-color: var(--primary); }
        .stat-card.success { border-left-color: var(--success); }
        .stat-card.info { border-left-color: var(--info); }
        .stat-card.warning { border-left-color: var(--warning); }

        .stat-title {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 5px;
        }

        .stat-value {
            font-size: 1.25rem;
            font-weight: 800;
            color: #5a5c69;
        }

        .stat-icon {
            font-size: 2rem;
            color: #dddfeb;
        }

        /* Quick Action Cards */
        .action-card {
            text-decoration: none;
            display: block;
            padding: 1.5rem;
            text-align: center;
            border-radius: 15px;
            color: white;
            height: 100%;
            transition: all 0.3s ease;
        }

        .action-card i {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            display: block;
        }

        .action-card span {
            font-weight: 700;
            font-size: 1rem;
        }

        .ac-products { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .ac-orders { background: linear-gradient(135deg, #2af598 0%, #009efd 100%); }
        .ac-users { background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); }
        .ac-reviews { background: linear-gradient(135deg, #ff0844 0%, #ffb199 100%); }

        .action-card:hover {
            transform: scale(1.05);
            color: white;
            filter: brightness(1.1);
        }

        .section-title {
            font-weight: 800;
            color: var(--dark);
            margin-bottom: 1.5rem;
            position: relative;
            padding-left: 15px;
        }

        .section-title::before {
            content: '';
            position: absolute;
            left: 0;
            top: 5px;
            bottom: 5px;
            width: 5px;
            background: var(--primary);
            border-radius: 10px;
        }

        .table thead th {
            background-color: #f8f9fc;
            text-transform: uppercase;
            font-size: 0.75rem;
            font-weight: 700;
            color: #858796;
            border: none;
        }

        .badge-status {
            padding: 0.5em 0.8em;
            border-radius: 50rem;
            font-weight: 700;
            font-size: 0.7rem;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <%- include('partials/menu') %>

            <!-- Main Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="fw-bold mb-0">Bảng điều khiển</h2>
                        <p class="text-muted">Chào mừng trở lại, hệ thống đang hoạt động ổn định.</p>
                    </div>
                    <%- include('partials/account_dropdown') %>
                </div>

                <!-- Thống kê nhanh -->
                <div class="row g-4 mb-5">
                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card primary h-100">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <div class="stat-title text-primary">Doanh thu (Tổng)</div>
                                    <div class="stat-value"><%= stats.revenue.toLocaleString('vi-VN') %> đ</div>
                                </div>
                                <i class="fas fa-calendar-check stat-icon"></i>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card success h-100">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <div class="stat-title text-success">Đơn hàng</div>
                                    <div class="stat-value"><%= stats.orders %></div>
                                </div>
                                <i class="fas fa-shopping-cart stat-icon"></i>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card info h-100">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <div class="stat-title text-info">Khách hàng</div>
                                    <div class="stat-value"><%= stats.users %></div>
                                </div>
                                <i class="fas fa-user-friends stat-icon"></i>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-3 col-md-6">
                        <div class="card stat-card warning h-100">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <div class="stat-title text-warning">Sắp hết hàng</div>
                                    <div class="stat-value"><%= stats.lowStock %></div>
                                </div>
                                <i class="fas fa-box-open stat-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Truy cập nhanh -->
                <h4 class="section-title">Truy cập nhanh</h4>
                <div class="row g-4 mb-5">
                    <div class="col-6 col-lg-3">
                        <a href="/admin/products" class="action-card ac-products">
                            <i class="fas fa-book"></i>
                            <span>Quản lý Sản phẩm</span>
                        </a>
                    </div>
                    <div class="col-6 col-lg-3">
                        <a href="/admin/orders" class="action-card ac-orders">
                            <i class="fas fa-file-invoice-dollar"></i>
                            <span>Quản lý Đơn hàng</span>
                        </a>
                    </div>
                    <div class="col-6 col-lg-3">
                        <a href="/admin/user" class="action-card ac-users">
                            <i class="fas fa-users-cog"></i>
                            <span>Quản lý Người dùng</span>
                        </a>
                    </div>
                    <div class="col-6 col-lg-3">
                        <a href="/admin/reviews" class="action-card ac-reviews">
                            <i class="fas fa-star"></i>
                            <span>Duyệt Đánh giá</span>
                        </a>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- Biểu đồ doanh thu -->
                    <div class="col-xl-8">
                        <div class="card h-100">
                            <div class="card-header bg-white py-3">
                                <h6 class="m-0 fw-bold text-primary">Biểu đồ doanh thu (7 ngày qua)</h6>
                            </div>
                            <div class="card-body">
                                <canvas id="revenueChart" height="300"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- Đơn hàng mới nhất -->
                    <div class="col-xl-4">
                        <div class="card h-100">
                            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                                <h6 class="m-0 fw-bold text-primary">Đơn hàng mới nhất</h6>
                                <a href="/admin/orders" class="btn btn-sm btn-link text-decoration-none">Xem tất cả</a>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <tbody>
                                            <% if (recentOrders && recentOrders.length > 0) { %>
                                                <% recentOrders.forEach(order => { %>
                                                    <tr>
                                                        <td class="ps-3">
                                                            <div class="fw-bold">#<%= order.id %></div>
                                                            <small class="text-muted"><%= new Date(order.order_date).toLocaleDateString('vi-VN') %></small>
                                                        </td>
                                                        <td>
                                                            <div class="fw-bold text-dark"><%= order.final_total.toLocaleString('vi-VN') %>đ</div>
                                                        </td>
                                                        <td class="pe-3 text-end">
                                                            <%
                                                                let badgeClass = 'bg-secondary';
                                                                if(order.status === 'COMPLETED') badgeClass = 'bg-success';
                                                                else if(order.status === 'PENDING') badgeClass = 'bg-warning text-dark';
                                                                else if(order.status === 'SHIPPING') badgeClass = 'bg-info';
                                                            %>
                                                            <span class="badge badge-status <%= badgeClass %>"><%= order.status %></span>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } else { %>
                                                <tr><td colspan="3" class="text-center py-4 text-muted">Chưa có đơn hàng nào.</td></tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Data for Chart -->
    <div id="chartData" data-revenue='<%= JSON.stringify(revenueChart || []) %>' style="display:none;"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const chartDataEl = document.getElementById('chartData');
            const revenueData = JSON.parse(chartDataEl.dataset.revenue);

            const labels = revenueData.map(item => {
                const d = new Date(item.date);
                return d.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit' });
            });
            const data = revenueData.map(item => Number(item.revenue) || 0);

            const ctx = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu',
                        data: data,
                        borderColor: '#4e73df',
                        backgroundColor: 'rgba(78, 115, 223, 0.05)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#4e73df'
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return value.toLocaleString('vi-VN') + ' đ';
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
</body>
</html>