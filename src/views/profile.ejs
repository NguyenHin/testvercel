<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Thông tin tài khoản - BookTotal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', sans-serif; }
        .profile-wrapper { margin-top: 30px; margin-bottom: 50px; }
        .profile-card { background: #ffffff; border-radius: 12px; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05); padding: 25px 30px; }
        .profile-title { font-size: 1.4rem; font-weight: 700; color: #1a1a2e; margin-bottom: 5px; }
        .section-header { font-weight: 600; margin-bottom: 15px; color: #495057; text-transform: uppercase; font-size: 0.9rem; border-bottom: 2px solid #eee; padding-bottom: 5px; }
        .form-label { font-weight: 600; font-size: 0.9rem; }
        .btn-primary-custom { background: linear-gradient(45deg, #ffc107, #ffb300); border-color: #ffb300; color: #212529; font-weight: 700; }
        .toggle-password { cursor: pointer; }
    </style>
</head>

<body>
    <%- include('partials/menu') %>

    <div class="container profile-wrapper">
        <div class="profile-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <div class="profile-title"><i class="fas fa-user-circle me-2 text-primary"></i>Hồ sơ của tôi</div>
                    <div class="text-muted small">Quản lý thông tin hồ sơ để bảo mật tài khoản</div>
                </div>
                <span class="badge bg-info text-uppercase"><%= userInfo.role %></span>
            </div>

            <!-- Thông báo -->
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i><%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i><%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <div class="row g-5">
                <!-- Cập nhật thông tin -->
                <div class="col-md-6">
                    <div class="section-header"><i class="fas fa-edit me-2"></i>Thông tin cá nhân</div>
                    <form action="/profile" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Tên đăng nhập</label>
                            <input type="text" class="form-control bg-light" value="<%= userInfo.username %>" readonly>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Họ và tên</label>
                            <input type="text" class="form-control" name="full_name" value="<%= userInfo.full_name %>" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" name="email" value="<%= userInfo.email %>" required>
                        </div>
                        <button type="submit" class="btn btn-primary-custom w-100 mt-2">Lưu thay đổi</button>
                    </form>
                </div>

                <!-- Đổi mật khẩu -->
                <div class="col-md-6">
                    <div class="section-header"><i class="fas fa-shield-alt me-2"></i>Đổi mật khẩu</div>
                    <form action="/profile/change-password" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu hiện tại</label>
                            <div class="input-group">
                                <input type="password" class="form-control" name="current_password" required>
                                <span class="input-group-text toggle-password"><i class="fas fa-eye"></i></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <div class="input-group">
                                <input type="password" class="form-control" name="new_password" required>
                                <span class="input-group-text toggle-password"><i class="fas fa-eye"></i></span>
                            </div>
                            <div class="text-muted small mt-1">Tối thiểu 6 ký tự, có chữ hoa, chữ thường và ký tự đặc biệt.</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Xác nhận mật khẩu mới</label>
                            <div class="input-group">
                                <input type="password" class="form-control" name="confirm_password" required>
                                <span class="input-group-text toggle-password"><i class="fas fa-eye"></i></span>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-dark w-100 mt-2">Cập nhật mật khẩu</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelectorAll('.toggle-password').forEach(span => {
            span.addEventListener('click', function() {
                const input = this.parentElement.querySelector('input');
                const icon = this.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.replace('fa-eye', 'fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.replace('fa-eye-slash', 'fa-eye');
                }
            });
        });
    </script>
</body>
</html>
